{
  "name": "@sparx/commerce",
  "version": "0.0.0",
  "private": true,
  "description": "Sparx Commerce — service layer (single source of truth shared by REST, GraphQL, MCP, Server Actions, storefront, and B2B portal), event consumers, MCP tool registry. Mirrors @sparx/crm's locked decision #7 architecture: one service layer, many transports.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./services": {
      "types": "./src/services/index.ts",
      "default": "./src/services/index.ts"
    },
    "./mcp": {
      "types": "./src/mcp/index.ts",
      "default": "./src/mcp/index.ts"
    },
    "./manifest": {
      "types": "./src/manifest.ts",
      "default": "./src/manifest.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf .turbo dist *.tsbuildinfo"
  },
  "dependencies": {
    "@sparx/auth": "workspace:*",
    "@sparx/commerce-schemas": "workspace:*",
    "@sparx/crm": "workspace:*",
    "@sparx/crm-schemas": "workspace:*",
    "@sparx/db": "workspace:*",
    "@sparx/events": "workspace:*",
    "@sparx/integration-framework": "workspace:*",
    "@sparx/search": "workspace:*",
    "@sparx/ui": "workspace:*",
    "lucide-react": "^0.469.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
