{
  "name": "@sparx/events",
  "version": "0.0.0",
  "private": true,
  "description": "Shared event type registry + Pub/Sub publisher. Used by api-rest, dashboard (Better Auth callbacks), and any future service that needs to emit a typed event onto the per-topic Pub/Sub fan-out.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf .turbo dist *.tsbuildinfo"
  },
  "dependencies": {
    "@google-cloud/pubsub": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
