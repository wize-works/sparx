{
  "name": "@sparx/customer-auth",
  "version": "0.0.0",
  "private": true,
  "description": "Layer-2 storefront shopper authentication — tenant-scoped credentials, Argon2id hashing, opaque sessions. Distinct from @sparx/auth (staff Better Auth). See docs/27-customer-accounts-storefront-auth.md.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf .turbo dist *.tsbuildinfo"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@sparx/db": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
