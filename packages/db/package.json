{
  "name": "@sparx/db",
  "version": "0.0.0",
  "private": true,
  "description": "Sparx data layer — Prisma client, schema, migrations, and tenant-context helpers for Cloud SQL Postgres 18.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    }
  },
  "files": [
    "src",
    "prisma"
  ],
  "scripts": {
    "build": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:up": "docker compose -f docker-compose.yml up -d",
    "db:down": "docker compose -f docker-compose.yml down",
    "db:rls-audit": "tsx scripts/rls-audit.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo dist *.tsbuildinfo"
  },
  "dependencies": {
    "@prisma/client": "^6.2.0",
    "@node-rs/argon2": "^2.0.2",
    "@google-cloud/secret-manager": "^5.6.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/pg": "^8.11.10",
    "prisma": "^6.2.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  }
}
