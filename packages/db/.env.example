# Sparx data layer — local dev defaults.
#
# Production uses Cloud SQL Postgres 18 over the Cloud SQL Auth Proxy; the URL
# is injected from Secret Manager (per docs/03-infrastructure-deployment.md).
#
# For local dev, `pnpm --filter @sparx/db db:up` brings up Postgres 18 via the
# co-located docker-compose.yml on port 5544 (offset to avoid colliding with
# any system Postgres).
#
# Two roles:
#   - sparx_owner: schema migrations (BYPASSRLS implicit as table owner)
#   - sparx_app:   runtime queries; subject to FORCE RLS, sets app.tenant_id
#
# DATABASE_URL is what the Prisma client uses at runtime → sparx_app.
# MIGRATION_DATABASE_URL is what `prisma migrate` uses → sparx_owner.

DATABASE_URL="postgresql://sparx_app:devpassword@localhost:5544/sparx?schema=public"
MIGRATION_DATABASE_URL="postgresql://sparx_owner:devpassword@localhost:5544/sparx?schema=public"
