// Commerce — Per-tenant storefront settings + theme token overrides.
// Sitebuilder owns layout + page composition (separate module);
// Commerce owns the commerce-side defaults (currency, default warehouse,
// channels enabled, abandonment threshold) and the limited set of theme
// tokens a tenant can override without touching Sitebuilder.

model StorefrontSettings {
  tenantId String @id @map("tenant_id") @db.Uuid

  defaultCurrency         String  @default("USD") @map("default_currency") @db.VarChar(3)
  defaultLocale           String  @default("en-US") @map("default_locale") @db.VarChar(10)
  defaultWarehouseId      String? @map("default_warehouse_id") @db.Uuid
  channelsEnabled         Json    @default("[\"storefront\"]") @map("channels_enabled")
  cartAbandonmentMinutes  Int     @default(120) @map("cart_abandonment_minutes")
  showStockBelow          Int     @default(10) @map("show_stock_below")
  hidePricesWhenSignedOut Boolean @default(false) @map("hide_prices_when_signed_out")
  requireAuthForCheckout  Boolean @default(false) @map("require_auth_for_checkout")

  // Default dunning policy used by every subscription on this tenant
  // unless overridden per-subscription.
  defaultDunningPolicy Json @default("{}") @map("default_dunning_policy")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("commerce_storefront_settings")
}

// PRESENTATION-only token overrides applied on top of @sparx/ui's storefront
// variants. Brand IDENTITY (primary/accent colour, typography, logo, favicon)
// is owned by the tenant-level TenantBrand (docs/30 §6) and read live + overlaid
// at render — it is NOT mirrored here. The former identity columns
// (color_primary/_primary_foreground/_accent, font_heading/_body,
// logo_media_id/logo_dark_media_id/favicon_media_id) were removed in migration
// 20260610000200 once every reader cut over to brand.

model StorefrontTheme {
  tenantId String @id @map("tenant_id") @db.Uuid

  colorBackground String? @map("color_background") @db.VarChar(7)
  colorMuted      String? @map("color_muted") @db.VarChar(7)
  radiusBase      String? @map("radius_base") @db.VarChar(15)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("commerce_storefront_themes")
}
