// Commerce — Subscriptions (auto-ship). First-class recurring orders for
// dogfood / diesel-additive / supplement merchants. SubscriptionBilling
// provider (Stripe by default) drives the actual charge schedule; the
// subscription-billing-worker advances Sparx state on the back of
// provider webhook events.

model Subscription {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String  @map("tenant_id") @db.Uuid
  customerId    String  @map("customer_id") @db.Uuid
  channel       String  @default("storefront") @db.VarChar(20)
  currency      String  @db.VarChar(3)

  status String @default("active") @db.VarChar(20)
  // ^ trialing | active | past_due | paused | cancelled

  // Provider linkage — slug + provider's internal schedule ref.
  providerSlug        String  @map("provider_slug") @db.VarChar(63)
  providerCustomerRef String? @map("provider_customer_ref") @db.VarChar(255)
  providerScheduleRef String? @map("provider_schedule_ref") @db.VarChar(255)

  // Schedule shape — the worker reads these to compute next occurrences
  // when the provider doesn't drive the cadence.
  intervalUnit         String  @map("interval_unit") @db.VarChar(10) // day | week | month | year
  intervalCount        Int     @map("interval_count")
  deliveriesPerCycle   Int     @default(1) @map("deliveries_per_cycle")
  anchorDayOfMonth     Int?    @map("anchor_day_of_month")
  anchorDayOfWeek      Int?    @map("anchor_day_of_week")
  endAfterOccurrences  Int?    @map("end_after_occurrences")
  endOnDate            DateTime? @map("end_on_date") @db.Timestamptz

  // Address snapshots used for renewal orders; can be changed mid-cycle
  // via subscriptionService.changeAddress.
  shippingAddress Json @map("shipping_address")
  billingAddress  Json? @map("billing_address")

  // Lifecycle timestamps.
  startedAt           DateTime? @map("started_at") @db.Timestamptz
  trialEndsAt         DateTime? @map("trial_ends_at") @db.Timestamptz
  currentPeriodStart  DateTime? @map("current_period_start") @db.Timestamptz
  currentPeriodEnd    DateTime? @map("current_period_end") @db.Timestamptz
  nextOccurrenceAt    DateTime? @map("next_occurrence_at") @db.Timestamptz
  pausedUntil         DateTime? @map("paused_until") @db.Timestamptz
  cancelledAt         DateTime? @map("cancelled_at") @db.Timestamptz

  // Dunning policy override per subscription; null = use tenant default.
  dunningPolicy Json? @map("dunning_policy")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  items     SubscriptionItem[]
  events    SubscriptionEvent[]
  dunningAttempts DunningAttempt[]

  @@index([tenantId, customerId])
  @@index([tenantId, status])
  @@index([nextOccurrenceAt])
  @@map("commerce_subscriptions")
}

model SubscriptionItem {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String @map("tenant_id") @db.Uuid
  subscriptionId String @map("subscription_id") @db.Uuid
  variantId      String @map("variant_id") @db.Uuid
  quantity       Int    @default(1)
  unitPriceCents Int    @map("unit_price_cents")

  // Configurator selection (when the item resolves through a configurator
  // template at signup time). Stored intact so renewals stay deterministic.
  configurationPayload Json? @map("configuration_payload")

  // Add-on parent — used when an item was added by a configurator rule
  // ("add a slide pack to the swing set"). The parent SubscriptionItem
  // is the primary; this row carries the add-on alongside it.
  addonOfId String? @map("addon_of_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription   @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  variant      ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  addonOf      SubscriptionItem? @relation("SubscriptionItemAddon", fields: [addonOfId], references: [id], onDelete: SetNull)
  addons       SubscriptionItem[] @relation("SubscriptionItemAddon")

  @@index([tenantId, subscriptionId])
  @@index([variantId])
  @@map("commerce_subscription_items")
}

// Audit-log-shaped event stream — created, renewed, paused, etc. Used
// by the storefront customer-facing subscription history surface.

model SubscriptionEvent {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  subscriptionId String   @map("subscription_id") @db.Uuid
  event          String   @db.VarChar(40)
  // ^ created | renewed | payment_failed | paused | resumed | cancelled | skipped | item_changed | address_changed
  payload        Json     @default("{}")
  actorUserId    String?  @map("actor_user_id") @db.Uuid
  occurredAt     DateTime @default(now()) @map("occurred_at") @db.Timestamptz

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([tenantId, subscriptionId, occurredAt(sort: Desc)])
  @@map("commerce_subscription_events")
}

// Per-subscription retry attempt log. The subscription-billing-worker
// reads the tail of this to decide whether to retry, escalate, or
// follow the policy's finalOutcome.

model DunningAttempt {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  subscriptionId String   @map("subscription_id") @db.Uuid
  paymentRef     String?  @map("payment_ref") @db.VarChar(255)
  attemptNumber  Int      @map("attempt_number")
  outcome        String   @db.VarChar(20) // pending | succeeded | failed | retry_scheduled
  failureReason  String?  @map("failure_reason") @db.Text
  attemptedAt    DateTime @default(now()) @map("attempted_at") @db.Timestamptz
  nextRetryAt    DateTime? @map("next_retry_at") @db.Timestamptz

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([tenantId, subscriptionId, attemptedAt(sort: Desc)])
  @@map("commerce_dunning_attempts")
}
