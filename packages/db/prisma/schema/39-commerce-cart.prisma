// Commerce — Cart, cart items, applied discounts. Cart is the only thing
// storefront/B2B writes before checkout; once a CheckoutSession is
// created the cart freezes.

model Cart {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  customerId  String? @map("customer_id") @db.Uuid
  guestToken  String? @map("guest_token") @db.VarChar(127)
  channel     String  @db.VarChar(20) // storefront | b2b_portal | admin | mcp
  currency    String  @db.VarChar(3)

  // Source provenance — populated when the cart was bootstrapped from
  // an existing quote or subscription. Both nullable; CRM owns the rows.
  fromQuoteId        String? @map("from_quote_id") @db.Uuid
  fromSubscriptionId String? @map("from_subscription_id") @db.Uuid

  // Cached totals; the deterministic pricing pipeline writes these on
  // every cart mutation so the storefront can render without recomputing.
  subtotalCents          Int @default(0) @map("subtotal_cents")
  discountTotalCents     Int @default(0) @map("discount_total_cents")
  shippingTotalCents     Int @default(0) @map("shipping_total_cents")
  taxTotalCents          Int @default(0) @map("tax_total_cents")
  giftCardAppliedCents   Int @default(0) @map("gift_card_applied_cents")
  storeCreditAppliedCents Int @default(0) @map("store_credit_applied_cents")
  totalCents             Int @default(0) @map("total_cents")

  // Per-tenant pricing trace — every step of the resolution pipeline is
  // recorded here so the storefront can answer "why is this the price?"
  // without re-running the math.
  pricingTrace Json @default("{}") @map("pricing_trace")

  expiresAt   DateTime? @map("expires_at") @db.Timestamptz
  abandonedAt DateTime? @map("abandoned_at") @db.Timestamptz
  recoveredAt DateTime? @map("recovered_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer  Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items     CartItem[]
  discounts CartDiscount[]
  checkoutSessions CheckoutSession[]

  @@index([tenantId, customerId])
  @@index([tenantId, guestToken])
  @@index([tenantId, abandonedAt])
  @@index([tenantId, updatedAt(sort: Desc)])
  @@map("commerce_carts")
}

model CartItem {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String @map("tenant_id") @db.Uuid
  cartId    String @map("cart_id") @db.Uuid
  variantId String @map("variant_id") @db.Uuid
  quantity  Int    @default(1)

  unitPriceCents Int @map("unit_price_cents")
  subtotalCents  Int @map("subtotal_cents")

  // Configurator payload (when the variant is the resolution of a
  // configurable parent). Stored intact so the line item can be
  // re-resolved on price refresh.
  configurationPayload Json? @map("configuration_payload")
  attributes           Json  @default("{}")

  // Per-line trace from pricingService.resolve.
  unitPriceTrace Json @default("[]") @map("unit_price_trace")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([tenantId, cartId])
  @@index([variantId])
  @@map("commerce_cart_items")
}

// Applied discounts on a cart. A cart can carry multiple (when stacking
// rules permit). Applied gift cards live alongside in cartGiftCards
// (next model).

model CartDiscount {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  cartId      String   @map("cart_id") @db.Uuid
  discountId  String   @map("discount_id") @db.Uuid
  appliedCents Int     @map("applied_cents")
  appliedAt   DateTime @default(now()) @map("applied_at") @db.Timestamptz

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cart     Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  discount Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)

  @@unique([cartId, discountId], map: "cart_discounts_unique")
  @@index([tenantId, cartId])
  @@map("commerce_cart_discounts")
}
