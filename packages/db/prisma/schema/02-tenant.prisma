// Tenant — the dispatch row every other table FKs back to. Better Auth's
// `organization` plugin maps 1:1 onto this row (docs/16 §2 Layer 1) — the
// org id will be stored alongside this tenant when Better Auth is wired in.
//
// This file is unavoidably the "relation hub" — every module that owns
// tenant-scoped tables declares an inverse relation here. New modules add
// their array to the matching section below; the field count is a quick
// way to see how much surface the platform exposes per tenant.

model Tenant {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug             String    @unique @db.VarChar(63)
  name             String    @db.VarChar(255)
  email            String    @db.VarChar(255)
  plan             String    @default("starter") @db.VarChar(50)
  status           String    @default("active") @db.VarChar(20)
  settings         Json      @default("{}")
  stripeCustomerId String?   @map("stripe_customer_id") @db.VarChar(255)
  trialEndsAt      DateTime? @map("trial_ends_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Platform core — brand identity (tenant-level source of truth, docs/30 §6)
  brand TenantBrand?

  // Auth + audit
  users     User[]
  auditLogs AuditLog[]
  apiKeys   ApiKey[]

  // Dashboard shell — per-user pinned/recent navigation state
  userFavorites UserFavorite[]
  userRecents   UserRecent[]

  // CMS module
  pages                Page[]
  contentTypes         ContentType[]
  contentEntries       ContentEntry[]
  contentRevisions     ContentRevision[]
  contentReferences    ContentReference[]
  taxonomies           Taxonomy[]
  taxonomyTerms        TaxonomyTerm[]
  entryTaxonomyTerms   EntryTaxonomyTerm[]
  authors              Author[]
  redirects            Redirect[]
  navigationMenus      NavigationMenu[]
  navigationItems      NavigationItem[]
  previewTokens        PreviewToken[]
  webhookSubscriptions WebhookSubscription[]
  webhookDeliveries    WebhookDelivery[]
  mediaAssets          MediaAsset[]
  mediaVariants        MediaVariant[]

  // CRM module — customer spine
  customers         Customer[]
  customerAddresses CustomerAddress[]
  b2bAccounts       B2BAccount[]

  // CRM module — sales pipeline
  pipelines      Pipeline[]
  pipelineStages PipelineStage[]
  deals          Deal[]
  dealOrders     DealOrder[]
  dealQuotes     DealQuote[]

  // CRM module — orders, payments, refunds, fulfillments
  orders                Order[]
  orderItems            OrderItem[]
  orderPayments         OrderPayment[]
  orderRefunds          OrderRefund[]
  orderRefundItems      OrderRefundItem[]
  orderFulfillments     OrderFulfillment[]
  orderFulfillmentItems OrderFulfillmentItem[]

  // CRM module — quotes
  quotes     Quote[]
  quoteItems QuoteItem[]

  // CRM module — activity, tasks, segments, views
  crmActivities  CrmActivity[]
  tasks          Task[]
  segments       Segment[]
  segmentMembers SegmentMember[]
  savedViews     SavedView[]

  // Commerce module — catalog
  products            Product[]
  productTranslations ProductTranslation[]
  productOptions      ProductOption[]
  productOptionValues ProductOptionValue[]
  productVariants     ProductVariant[]
  variantImages       VariantImage[]
  productCategories   ProductCategory[]
  productCollections  ProductCollection[]

  // Commerce module — fitment (generalized: vehicle, pet, device, ...)
  fitmentDomains    FitmentDomain[]
  fitmentCategories FitmentCategory[]
  fitmentItems      FitmentItem[]
  fitmentVariants   FitmentVariant[]
  productFitments   ProductFitment[]

  // Commerce module — inventory + lots
  warehouses            Warehouse[]
  inventoryLevels       InventoryLevel[]
  inventoryAdjustments  InventoryAdjustment[]
  inventoryReservations InventoryReservation[]
  lotBatches            LotBatch[]
  serialUnits           SerialUnit[]

  // Commerce module — pricing + discounts
  priceLists              PriceList[]
  priceListEntries        PriceListEntry[]
  bulkPriceTiers          BulkPriceTier[]
  contractPrices          ContractPrice[]
  discounts               Discount[]
  discountUsages          DiscountUsage[]
  giftCards               GiftCard[]
  giftCardTransactions    GiftCardTransaction[]
  storeCredits            StoreCredit[]
  storeCreditTransactions StoreCreditTransaction[]

  // Commerce module — bundles + configurator
  bundles                Bundle[]
  bundleComponents       BundleComponent[]
  configurationTemplates ConfigurationTemplate[]
  configurationOptions   ConfigurationOption[]
  configurationRules     ConfigurationRule[]
  configurationAddOns    ConfigurationAddOn[]

  // Commerce module — cart + checkout
  carts            Cart[]
  cartItems        CartItem[]
  cartDiscounts    CartDiscount[]
  checkoutSessions CheckoutSession[]

  // Commerce module — subscriptions
  subscriptions      Subscription[]
  subscriptionItems  SubscriptionItem[]
  subscriptionEvents SubscriptionEvent[]
  dunningAttempts    DunningAttempt[]

  // Commerce module — reviews + Q&A + wishlists
  productReviews      ProductReview[]
  reviewMedia         ReviewMedia[]
  reviewHelpfulVotes  ReviewHelpfulVote[]
  reviewModerationLog ReviewModerationLog[]
  productQuestions    ProductQuestion[]
  productAnswers      ProductAnswer[]
  wishlists           Wishlist[]
  wishlistItems       WishlistItem[]

  // Commerce module — returns
  returnRequests    ReturnRequest[]
  returnLineItems   ReturnLineItem[]
  returnInspections ReturnInspection[]
  returnLabels      ReturnLabel[]

  // Commerce module — shipping
  shippingZones    ShippingZone[]
  shippingProfiles ShippingProfile[]
  shippingRates    ShippingRate[]

  // Commerce module — tax
  taxZones      TaxZone[]
  taxRates      TaxRate[]
  taxExemptions TaxExemption[]

  // Commerce module — provider marketplace
  providerInstallations ProviderInstallation[]
  providerWebhookEvents ProviderWebhookEvent[]

  // Commerce module — storefront defaults + theme
  storefrontSettings StorefrontSettings?
  storefrontTheme    StorefrontTheme?

  // Customer-auth (Layer 2) — storefront shopper credentials/sessions (docs/27)
  customerCredentials    CustomerCredential[]
  customerAuthSessions   CustomerSession[]
  customerPasswordResets CustomerPasswordReset[]

  // Sitebuilder module — theme/layout/page composition + publish history (docs/29)
  siteConfig           SiteConfig?
  siteVersions         SiteVersion[]
  siteSections         SiteSection[]
  siteLayoutBlocks     SiteLayoutBlock[]
  sitePublishSchedules SitePublishSchedule[]

  // Email platform — management surface (docs/13)
  emailSettings       EmailSettings?
  sendingDomains      SendingDomain[]
  emailTemplates      EmailTemplate[]
  emailAutomations    EmailAutomation[]
  emailScheduledSends ScheduledSend[]
  broadcasts          Broadcast[]
  emailEvents         EmailEvent[]
  emailSuppressions   EmailSuppression[]

  @@map("tenants")
}
