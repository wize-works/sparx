// CMS / platform — Webhooks.
//
// Outgoing webhooks for state-change events. Subscriptions describe what to
// listen to; deliveries are the retry queue with status / response capture.

model WebhookSubscription {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  name          String   @db.VarChar(120)
  url           String   @db.VarChar(2048)
  events        String[] @db.VarChar(120)
  signingSecret String   @map("signing_secret") @db.Text
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([tenantId, active])
  @@map("webhook_subscriptions")
}

model WebhookDelivery {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  subscriptionId String    @map("subscription_id") @db.Uuid
  eventType      String    @map("event_type") @db.VarChar(120)
  payload        Json
  attemptCount   Int       @default(0) @map("attempt_count")
  status         String    @default("pending") @db.VarChar(20)
  responseStatus Int?      @map("response_status")
  responseBody   String?   @map("response_body") @db.Text
  nextAttemptAt  DateTime? @map("next_attempt_at") @db.Timestamptz
  deliveredAt    DateTime? @map("delivered_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, nextAttemptAt])
  @@index([subscriptionId, createdAt(sort: Desc)])
  @@map("webhook_deliveries")
}
