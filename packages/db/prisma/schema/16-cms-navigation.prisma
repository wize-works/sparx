// CMS — navigation menus.
//
// Navigation menus are information architecture — content — and are owned by the
// CMS module: the merchant edits header / footer / mega / custom_* menus under
// the CMS dashboard (/cms/navigation), and the storefront renders them via the
// SiteLayoutBlock → NavigationMenu reference. Site Builder owns only the layout
// SLOTS (header/footer/announcement) that point at a menu; it does not own the
// menus themselves. See docs/30-sitebuilder-redesign.md §8.
//
// Items link to a CMS ContentEntry OR an external URL (exactly one, validated at
// the API). The `entry` relation is now an intra-module reference.
//
// Table names (navigation_menus / navigation_items) are unchanged across every
// ownership move this model has lived through (CMS → Site Builder → CMS) — the
// `@@map` is the contract, so relocating the model between schema files is a
// no-op at the database level, never a data migration.

model NavigationMenu {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  location  String   @db.VarChar(63)
  name      String   @db.VarChar(120)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items            NavigationItem[]
  // Site Builder header/footer slots reference this menu by id. docs/30 §8.
  siteLayoutBlocks SiteLayoutBlock[]

  @@unique([tenantId, location])
  @@map("navigation_menus")
}

model NavigationItem {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  menuId       String   @map("menu_id") @db.Uuid
  parentItemId String?  @map("parent_item_id") @db.Uuid
  position     Int
  label        String   @db.VarChar(255)
  entryId      String?  @map("entry_id") @db.Uuid
  externalUrl  String?  @map("external_url") @db.VarChar(2048)
  openInNewTab Boolean  @default(false) @map("open_in_new_tab")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  menu     NavigationMenu   @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parent   NavigationItem?  @relation("NavTree", fields: [parentItemId], references: [id], onDelete: Cascade)
  children NavigationItem[] @relation("NavTree")
  entry    ContentEntry?    @relation(fields: [entryId], references: [id], onDelete: SetNull)

  @@index([menuId, position])
  @@index([tenantId])
  @@map("navigation_items")
}
