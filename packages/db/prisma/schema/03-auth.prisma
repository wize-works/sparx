// Staff users + sessions + auth credentials (Layer 1 — merchant staff).
//
// Better Auth-compatible base columns + Sparx tenant/role extensions on
// `User`. Customer-facing accounts (Layer 2) live in `customers` and share
// zero rows with `users` per docs/16 §2.

model User {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // Globally unique — Better Auth's sign-in flow keys on email alone, and
  // signUpMerchant creates a fresh tenant per registration, so the older
  // @@unique([tenantId, email]) compound never fired in practice. The
  // CITEXT-equivalent normalisation lives at the app layer (signUpMerchant
  // lowercases before insert); the migration adds a case-insensitive
  // expression index as a backstop.
  email         String  @unique @db.VarChar(255)
  emailVerified Boolean @default(false) @map("email_verified")
  name          String? @db.VarChar(255)
  image         String? @db.Text

  // Sparx-specific extensions
  tenantId    String    @map("tenant_id") @db.Uuid
  role        String    @default("editor") @db.VarChar(50) // owner | admin | editor | viewer | api
  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions Session[]
  accounts Account[]

  // CRM module — staff acting as sales rep / task owner / activity actor
  assignedCustomers   Customer[]   @relation("CustomerAssignedRep")
  assignedB2bAccounts B2BAccount[] @relation("B2BAccountAssignedRep")
  assignedDeals       Deal[]       @relation("DealAssignedRep")
  assignedTasks       Task[]       @relation("TaskAssignedTo")
  createdTasks        Task[]       @relation("TaskCreatedBy")
  completedTasks      Task[]       @relation("TaskCompletedBy")
  createdQuotes       Quote[]      @relation("QuoteCreatedBy")

  @@index([tenantId])
  @@map("users")
}

// Refresh-token rows used by Better Auth (docs/16 §3). The access JWT is
// stateless; this table backs the rotating refresh token + device tracking.

model Session {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(255) // SHA-256 of refresh token
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  ipAddress String?  @map("ip_address") @db.Inet
  userAgent String?  @map("user_agent") @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// One row per (provider, userId). For email/password the providerId is
// "credential" and `password` carries the Argon2 hash; for OAuth providers
// it's "google" / "github" / etc. with access/refresh tokens.

model Account {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String    @map("user_id") @db.Uuid
  providerId            String    @map("provider_id") @db.VarChar(50)
  accountId             String    @map("account_id") @db.VarChar(255)
  password              String?   @db.Text
  accessToken           String?   @map("access_token") @db.Text
  refreshToken          String?   @map("refresh_token") @db.Text
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at") @db.Timestamptz
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at") @db.Timestamptz
  scope                 String?   @db.Text
  idToken               String?   @map("id_token") @db.Text
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

// Short-lived single-use tokens for magic links / email verification /
// password reset. `identifier` is typically the email; `value` is the
// hashed token; `expiresAt` is enforced by the auth service.

model Verification {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identifier String   @db.VarChar(255)
  value      String   @db.VarChar(255)
  expiresAt  DateTime @map("expires_at") @db.Timestamptz
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([identifier])
  @@index([expiresAt])
  @@map("verifications")
}
