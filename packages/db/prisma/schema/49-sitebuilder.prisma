// Sitebuilder — theme selection, page/section composition, layout slots,
// and the draft → publish → schedule → rollback lifecycle (docs/29).
//
// SiteConfig is the editable source of truth (one per tenant). Publishing
// snapshots it into an immutable SiteVersion and write-through-compiles the
// light token subset into the commerce-owned StorefrontTheme row (the
// storefront's existing themeToCss() read path is unchanged). Sitebuilder
// never adds columns to commerce_storefront_themes and never writes CMS
// navigation rows — SiteLayoutBlock only *references* a NavigationMenu.
//
// Tenant-scoped + FORCE RLS so a callsite that forgets withTenant() returns
// nothing rather than leaking cross-tenant site config.

// One row per tenant — the working draft + pointer to the live version.
model SiteConfig {
  tenantId String @id @map("tenant_id") @db.Uuid

  themeKey         String @default("apex") @map("theme_key") @db.VarChar(63)
  // light-only | dark-only | auto | toggle
  appearancePolicy String @default("light-only") @map("appearance_policy") @db.VarChar(20)
  // Merchant overlay: { colors: { light, dark }, typography, layout, customCss }.
  // Shape validated by @sparx/sitebuilder-schemas, not the DB.
  draftSettings    Json   @default("{}") @map("draft_settings")

  publishedVersionId String? @unique @map("published_version_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  publishedVersion SiteVersion? @relation("PublishedVersion", fields: [publishedVersionId], references: [id], onDelete: SetNull)

  @@map("sitebuilder_configs")
}

// Immutable published snapshot. Rollback = copy a snapshot back into the
// draft and republish (creating a new version). compiledTokens holds the
// exact { light, dark } maps so a rollback re-writes StorefrontTheme
// deterministically without recompiling.
model SiteVersion {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  versionNumber    Int    @map("version_number")
  themeKey         String @map("theme_key") @db.VarChar(63)
  appearancePolicy String @map("appearance_policy") @db.VarChar(20)

  settingsSnapshot Json @map("settings_snapshot")
  sectionsSnapshot Json @map("sections_snapshot")
  layoutSnapshot   Json @map("layout_snapshot")
  compiledTokens   Json @map("compiled_tokens")

  publishedById String? @map("published_by_id") @db.Uuid
  note          String? @db.VarChar(500)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Back-relation for SiteConfig.publishedVersion (the currently-live snapshot).
  publishedByConfig SiteConfig? @relation("PublishedVersion")

  @@unique([tenantId, versionNumber])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("sitebuilder_versions")
}

// PageLayout — a reusable page layout for a layout TARGET (docs/30 §4, docs/36
// PageLayout tier; docs/handoffs/sitebuilder-pb-spec.md). Sections (SiteSection)
// hang off a layout. `targetId` is the data-driven layout-target id (docs/36 §4 —
// `commerce:product`, `cms:content-page`, `cms:content-type:<id>`, …) that
// determines the layout's data context + allowed section types; it replaced the
// old fixed `scope` enum (P-B). `key` is stable within (tenant, targetId) —
// "default" for a target's single layout, a slug for cms:content-page standalone
// pages. Tenant-scoped, ENABLE+FORCE RLS.
model PageLayout {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  targetId String @map("target_id") @db.VarChar(63)
  key      String @db.VarChar(255)
  name     String @db.VarChar(255)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sections    SiteSection[]
  defaults    SiteLayoutDefault[]
  assignments SiteLayoutAssignment[]

  @@unique([tenantId, targetId, key])
  @@index([tenantId, targetId])
  @@map("sitebuilder_page_layouts")
}

// Draft page composition — one row per section instance, hanging off a
// PageLayout. Published copies are denormalized into SiteVersion.sectionsSnapshot
// (which also carries the owning layout's targetId/key so old + new snapshots
// both resolve).
model SiteSection {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String @map("tenant_id") @db.Uuid
  pageLayoutId String @map("page_layout_id") @db.Uuid

  sectionType String  @map("section_type") @db.VarChar(63)
  position    Int
  visible     Boolean @default(true)
  config      Json    @default("{}")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pageLayout PageLayout @relation(fields: [pageLayoutId], references: [id], onDelete: Cascade)

  @@index([tenantId, pageLayoutId, position])
  @@map("sitebuilder_sections")
}

// Header / footer / announcement composition. navigationMenuId points at a
// CMS-owned NavigationMenu (reference only — CMS stays the sole writer of
// nav rows). config carries slot extras (announcement text, footer social
// links, logo placement, container width).
model SiteLayoutBlock {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  // header | footer | announcement
  slot             String  @db.VarChar(31)
  navigationMenuId String? @map("navigation_menu_id") @db.Uuid
  config           Json    @default("{}")
  visible          Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  navigationMenu NavigationMenu? @relation(fields: [navigationMenuId], references: [id], onDelete: SetNull)

  @@unique([tenantId, slot])
  @@index([tenantId])
  @@map("sitebuilder_layout_blocks")
}

// Scheduled publish records. The in-process tick scans (status, scheduled_at)
// via a SECURITY DEFINER function and runs publish-service.publishNow per
// due tenant.
model SitePublishSchedule {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  scheduledAt DateTime @map("scheduled_at") @db.Timestamptz
  // pending | published | cancelled | failed
  status      String   @default("pending") @db.VarChar(20)
  note        String?  @db.VarChar(500)
  createdById String?  @map("created_by_id") @db.Uuid

  // Optional saved theme to apply to the draft before this scheduled publish
  // snapshots — seasonal/holiday theme swaps (docs/36). SET NULL if the saved
  // theme is later deleted (the publish then just uses the current draft theme).
  themeId String? @map("theme_id") @db.Uuid

  processedAt     DateTime? @map("processed_at") @db.Timestamptz
  resultVersionId String?   @map("result_version_id") @db.Uuid
  error           String?   @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  theme  SiteTheme? @relation(fields: [themeId], references: [id], onDelete: SetNull)

  @@index([status, scheduledAt])
  @@index([tenantId, scheduledAt(sort: Desc)])
  @@map("sitebuilder_publish_schedules")
}

// A merchant-saved theme variant (docs/36 Brand+Theme tier). The tenant's own
// NAMED presentation snapshots — distinct from the read-only platform presets
// (THEME_LIST in @sparx/storefront-themes, which stay code-first). `presentation`
// is the Token-Model-v2 presentation overlay only (brand identity/feel stay
// brand-owned); `basePresetKey` is the preset it layers on. Applied to the draft
// (theme_key + draftSettings presentation) on "Use this theme" or by a scheduled
// publish that points at it. Tenant-scoped, ENABLE+FORCE RLS.
model SiteTheme {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  name          String @db.VarChar(120)
  basePresetKey String @map("base_preset_key") @db.VarChar(63)
  presentation  Json   @default("{}") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant    Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  schedules SitePublishSchedule[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("sitebuilder_themes")
}

// Per-target tenant default layout (docs/36 §6, docs/handoffs/sitebuilder-pc-spec.md).
// Which PageLayout renders by default for a layout target when an item has no
// per-item override. Absent → the target's `key='default'` layout, then the code
// default. Tenant-scoped, ENABLE+FORCE RLS.
model SiteLayoutDefault {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String @map("tenant_id") @db.Uuid
  targetId     String @map("target_id") @db.VarChar(63)
  pageLayoutId String @map("page_layout_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pageLayout PageLayout @relation(fields: [pageLayoutId], references: [id], onDelete: Cascade)

  @@unique([tenantId, targetId])
  @@index([tenantId])
  @@map("sitebuilder_layout_defaults")
}

// Per-item layout override (docs/36 §6). Pins one record (a product, collection,
// or content entry — by its STABLE id) to a specific PageLayout, overriding the
// per-target default. `itemRef` is the owning module's record id; SB references
// it without a cross-module FK (the module owns its data). Tenant-scoped, RLS.
model SiteLayoutAssignment {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String @map("tenant_id") @db.Uuid
  targetId     String @map("target_id") @db.VarChar(63)
  itemRef      String @map("item_ref") @db.VarChar(255)
  pageLayoutId String @map("page_layout_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pageLayout PageLayout @relation(fields: [pageLayoutId], references: [id], onDelete: Cascade)

  @@unique([tenantId, targetId, itemRef])
  @@index([tenantId, targetId])
  @@map("sitebuilder_layout_assignments")
}
