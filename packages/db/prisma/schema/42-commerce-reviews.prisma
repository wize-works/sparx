// Commerce — Reviews, Q&A, wishlists. Moderation gate lives on the
// service layer; `review.published` event fires when status flips to
// `approved` so the storefront cache invalidates.

model ProductReview {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String  @map("tenant_id") @db.Uuid
  productId  String  @map("product_id") @db.Uuid
  variantId  String? @map("variant_id") @db.Uuid
  customerId String? @map("customer_id") @db.Uuid
  orderId    String? @map("order_id") @db.Uuid // populated → verified-purchase badge

  rating Int    @db.SmallInt
  title  String @db.VarChar(127)
  body   String @db.Text

  // Anonymous reviews use displayName; signed-in reviews fall back to the
  // customer's profile name.
  displayName String? @map("display_name") @db.VarChar(63)

  status         String    @default("pending") @db.VarChar(20)
  // ^ pending | approved | rejected | flagged
  moderationNote String?   @map("moderation_note") @db.Text
  moderatedBy    String?   @map("moderated_by") @db.Uuid
  moderatedAt    DateTime? @map("moderated_at") @db.Timestamptz

  // Merchant response — displayed beside the review.
  response         String?   @db.Text
  responseAuthorId String?   @map("response_author_id") @db.Uuid
  respondedAt      DateTime? @map("responded_at") @db.Timestamptz

  helpfulCount   Int @default(0) @map("helpful_count")
  unhelpfulCount Int @default(0) @map("unhelpful_count")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product       Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant       ProductVariant?       @relation(fields: [variantId], references: [id], onDelete: SetNull)
  customer      Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull)
  media         ReviewMedia[]
  helpfulVotes  ReviewHelpfulVote[]
  moderationLog ReviewModerationLog[]

  @@index([tenantId, productId, status])
  @@index([tenantId, status, createdAt(sort: Desc)])
  @@index([tenantId, customerId])
  @@map("commerce_product_reviews")
}

model ReviewMedia {
  id           String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String @map("tenant_id") @db.Uuid
  reviewId     String @map("review_id") @db.Uuid
  mediaAssetId String @map("media_asset_id") @db.Uuid
  position     Int    @default(0)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  review ProductReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([tenantId, reviewId])
  @@index([mediaAssetId])
  @@map("commerce_review_media")
}

// One vote per (review, voter). voterFingerprint is the hashed IP+UA
// for anonymous voters; customerId carries authenticated voters.

model ReviewHelpfulVote {
  id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String  @map("tenant_id") @db.Uuid
  reviewId         String  @map("review_id") @db.Uuid
  customerId       String? @map("customer_id") @db.Uuid
  voterFingerprint String  @map("voter_fingerprint") @db.VarChar(127)
  helpful          Boolean

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  review ProductReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([reviewId, voterFingerprint], map: "review_helpful_votes_unique")
  @@index([tenantId, reviewId])
  @@map("commerce_review_helpful_votes")
}

model ReviewModerationLog {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  reviewId    String  @map("review_id") @db.Uuid
  action      String  @db.VarChar(20) // submitted | approved | rejected | flagged | edited
  actorUserId String? @map("actor_user_id") @db.Uuid
  note        String? @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  review ProductReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([tenantId, reviewId, createdAt(sort: Desc)])
  @@map("commerce_review_moderation_log")
}

// ─── Q&A ──────────────────────────────────────────────────────────────

model ProductQuestion {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String  @map("tenant_id") @db.Uuid
  productId    String  @map("product_id") @db.Uuid
  customerId   String? @map("customer_id") @db.Uuid
  displayName  String? @map("display_name") @db.VarChar(63)
  body         String  @db.Text
  status       String  @default("pending") @db.VarChar(20)
  // ^ pending | published | rejected
  helpfulCount Int     @default(0) @map("helpful_count")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product  Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  answers  ProductAnswer[]

  @@index([tenantId, productId, status])
  @@map("commerce_product_questions")
}

model ProductAnswer {
  id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String  @map("tenant_id") @db.Uuid
  questionId       String  @map("question_id") @db.Uuid
  body             String  @db.Text
  isOfficial       Boolean @default(false) @map("is_official") // merchant staff answer
  authorCustomerId String? @map("author_customer_id") @db.Uuid
  authorUserId     String? @map("author_user_id") @db.Uuid
  helpfulCount     Int     @default(0) @map("helpful_count")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  question ProductQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([tenantId, questionId])
  @@map("commerce_product_answers")
}

// ─── Wishlists ────────────────────────────────────────────────────────

model Wishlist {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String  @map("tenant_id") @db.Uuid
  customerId String  @map("customer_id") @db.Uuid
  name       String  @default("My Wishlist") @db.VarChar(127)
  isPublic   Boolean @default(false) @map("is_public")
  shareToken String? @map("share_token") @db.VarChar(63)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items    WishlistItem[]

  @@unique([tenantId, shareToken], map: "wishlists_share_token_unique")
  @@index([tenantId, customerId])
  @@map("commerce_wishlists")
}

model WishlistItem {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String  @map("tenant_id") @db.Uuid
  wishlistId String  @map("wishlist_id") @db.Uuid
  variantId  String  @map("variant_id") @db.Uuid
  note       String? @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  wishlist Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, variantId], map: "wishlist_items_unique")
  @@index([tenantId, wishlistId])
  @@map("commerce_wishlist_items")
}
