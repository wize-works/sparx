// CMS — Authors, redirects, preview tokens.
//
// Editorial primitives that ride alongside the content model. Authors are
// distinct from User so a single user can publish under multiple pen names
// and an author can persist after the user row is removed.
//
// Navigation menus moved to the Site Builder module — see
// 50-sitebuilder-navigation.prisma. The tables (navigation_menus /
// navigation_items) are unchanged; only ownership of the model definitions
// moved.

model Author {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  userId        String?  @map("user_id") @db.Uuid
  slug          String   @db.VarChar(255)
  displayName   String   @map("display_name") @db.VarChar(255)
  bio           String?  @db.Text
  avatarAssetId String?  @map("avatar_asset_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  avatarAsset MediaAsset?    @relation(fields: [avatarAssetId], references: [id], onDelete: SetNull)
  entries     ContentEntry[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("authors")
}

// 301/302 manual redirects with chain/loop detection enforced at the API.

model Redirect {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  fromPath   String    @map("from_path") @db.VarChar(2048)
  toPath     String    @map("to_path") @db.VarChar(2048)
  statusCode Int       @default(301) @map("status_code")
  hitCount   BigInt    @default(0) @map("hit_count")
  lastHitAt  DateTime? @map("last_hit_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, fromPath])
  @@index([tenantId])
  @@map("redirects")
}

// HS256 JWTs are stateless; this row keyed on `jti` lets us revoke
// individual tokens (or all tokens for an entry) without rotating the
// tenant secret.

model PreviewToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  entryId    String    @map("entry_id") @db.Uuid
  issuedById String?   @map("issued_by_id") @db.Uuid
  jti        String    @unique @db.Uuid
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entry  ContentEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([tenantId, entryId])
  @@index([expiresAt])
  @@map("preview_tokens")
}
