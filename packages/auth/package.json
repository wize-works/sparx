{
  "name": "@sparx/auth",
  "version": "0.0.0",
  "private": true,
  "description": "Sparx authentication — Better Auth server + client configured with the Sparx Prisma adapter and tenant/organization plugin (docs/16-auth-security.md).",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "verify": "tsx scripts/verify-signup.ts",
    "clean": "rm -rf .turbo dist *.tsbuildinfo"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@sparx/db": "workspace:*",
    "@sparx/email": "workspace:*",
    "@sparx/events": "workspace:*",
    "better-auth": "^1.6.11"
  },
  "peerDependencies": {
    "next": "^16.0.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.0.0",
    "dotenv": "^17.4.2",
    "next": "^16.2.6",
    "react": "^19.0.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  }
}
