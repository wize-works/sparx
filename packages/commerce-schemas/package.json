{
  "name": "@sparx/commerce-schemas",
  "version": "0.0.0",
  "private": true,
  "description": "Sparx Commerce — Zod input/output schemas shared by REST, MCP, Server Actions, storefront, and B2B portal (docs/09-ecommerce-module-prd.md). Single source of truth for the shape of every Commerce write.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf .turbo dist *.tsbuildinfo"
  },
  "dependencies": {
    "@sparx/crm-schemas": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
