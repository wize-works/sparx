{
  "name": "@sparx/email-platform",
  "version": "0.0.0",
  "private": true,
  "description": "Sparx Email Platform — management service layer (settings, sending domains, templates, automations, broadcasts, suppressions, analytics) shared by REST + MCP + Server Actions. @sparx/email stays the render lib; this owns the domain logic (docs/13-email-platform-prd.md).",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./services": {
      "types": "./src/services/index.ts",
      "default": "./src/services/index.ts"
    },
    "./schemas": {
      "types": "./src/schemas/index.ts",
      "default": "./src/schemas/index.ts"
    },
    "./manifest": {
      "types": "./src/manifest.ts",
      "default": "./src/manifest.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf .turbo dist *.tsbuildinfo"
  },
  "dependencies": {
    "@sparx/cms-editor": "workspace:*",
    "@sparx/db": "workspace:*",
    "@sparx/email": "workspace:*",
    "@sparx/email-sections": "workspace:*",
    "@sparx/events": "workspace:*",
    "@sparx/storefront-themes": "workspace:*",
    "@sparx/ui": "workspace:*",
    "lucide-react": "^0.577.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
