{
  "name": "@sparx/sitebuilder",
  "version": "0.0.0",
  "private": true,
  "description": "Sparx Site Builder — service layer (theme/section/layout/publish/schedule), events, MCP tools, and dashboard manifest. One service, many transports (docs/29-sitebuilder-architecture.md).",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./services": {
      "types": "./src/services/index.ts",
      "default": "./src/services/index.ts"
    },
    "./manifest": {
      "types": "./src/manifest.ts",
      "default": "./src/manifest.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf .turbo dist *.tsbuildinfo"
  },
  "dependencies": {
    "@sparx/db": "workspace:*",
    "@sparx/sitebuilder-schemas": "workspace:*",
    "@sparx/storefront-themes": "workspace:*",
    "@sparx/ui": "workspace:*",
    "lucide-react": "^0.577.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
