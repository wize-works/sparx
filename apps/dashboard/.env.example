# Sparx Dashboard — local dev environment.
#
# Copy to .env to run `pnpm --filter @sparx/dashboard dev` end-to-end against
# the local Postgres started by `pnpm --filter @sparx/db db:up`.

# Database — must match packages/db/.env (the dashboard uses the same Prisma
# client). Use sparx_app (runtime, FORCE RLS) for the application connection.
DATABASE_URL="postgresql://sparx_app:devpassword@localhost:5544/sparx?schema=public"
# Auth service connects as sparx_owner so it can read users/sessions/accounts
# before a tenant context is established. See docs/16-auth-security.md §4 and
# packages/db/prisma/migrations/20260527162200_auth_tables_no_force_rls.
AUTH_DATABASE_URL="postgresql://sparx_owner:devpassword@localhost:5544/sparx?schema=public"

# Better Auth — secret for token signing + session cookie URL.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET="replace-me-in-each-environment"
BETTER_AUTH_URL="http://localhost:3001"
