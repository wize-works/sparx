# services/media-worker local dev defaults. Real values for sparx-prod come
# from the sparx-app-env ConfigMap + sparx-app-secrets Secret synced from
# Google Secret Manager. Copy this file to `.env` to run locally.
#
# Pub/Sub-push consumer: nothing pushes media.uploaded events to it in local
# dev, so it never actually touches Cloud Storage — it just idles on its
# listen port. The values below only need to satisfy boot-time validation.

NODE_ENV=development
LOG_LEVEL=debug
# Distinct local port — workers default to 8080; media-worker takes 8082 to
# avoid EADDRINUSE when the whole stack runs under `turbo run dev`.
PORT=8082

# Same docker-compose Postgres the rest of the stack uses.
DATABASE_URL="postgresql://sparx_app:devpassword@localhost:5544/sparx?schema=public"

# Cloud Storage buckets (required by src/env.ts). There is no real GCS locally;
# the worker only reads/writes buckets when it processes a media push, which
# doesn't happen in local dev. Placeholder names satisfy boot validation.
# GCS_MEDIA_PUBLIC_BUCKET defaults to GCS_MEDIA_BUCKET when unset.
GCS_MEDIA_BUCKET=sparx-media-dev
