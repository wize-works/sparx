# services/commerce-indexer local dev defaults. Real values for sparx-prod
# come from the sparx-app-env ConfigMap + sparx-app-secrets Secret synced from
# Google Secret Manager. Copy this file to `.env` to run locally.
#
# Pub/Sub-push consumer: nothing pushes commerce events to it in local dev, so
# it never connects to Typesense (ENSURE_SCHEMAS_ON_BOOT is false by default)
# — it just idles on its listen port. The values below only need to satisfy
# boot-time validation.

NODE_ENV=development
LOG_LEVEL=debug
# Distinct local port — workers default to 8080; commerce-indexer takes 8083
# to avoid EADDRINUSE when the whole stack runs under `turbo run dev`.
PORT=8083

# Same docker-compose Postgres the rest of the stack uses.
DATABASE_URL="postgresql://sparx_app:devpassword@localhost:5544/sparx?schema=public"

# Typesense. Phase 1 uses Postgres FTS, so Typesense isn't part of the default
# local stack; the worker only talks to it when a commerce event is pushed.
# Placeholder key satisfies boot validation — point host at localhost and set
# a real key if you do run Typesense locally.
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=dev-typesense-key
