# services/cache-revalidation-worker local dev defaults. Real values for
# sparx-prod come from the sparx-app-env ConfigMap + sparx-app-secrets Secret
# synced from Google Secret Manager. Copy this file to `.env` to run locally.
#
# This is a Pub/Sub-push consumer: in local dev nothing pushes to it, so it
# just idles on its listen port. The values below only need to satisfy
# boot-time validation (src/env.ts).

NODE_ENV=development
LOG_LEVEL=debug
# Distinct local port — every worker defaults to 8080, which collides when the
# whole stack runs under `turbo run dev`. cache-revalidation-worker owns 8080.
PORT=8080

# Same docker-compose Postgres the rest of the stack uses
# (packages/db/docker-compose.yml).
DATABASE_URL="postgresql://sparx_app:devpassword@localhost:5544/sparx?schema=public"

# The storefront's on-demand revalidation endpoint. Locally the storefront
# runs on :3004; in prod this defaults to the in-cluster service URL.
STOREFRONT_REVALIDATE_URL="http://localhost:3004/api/revalidate"
# SPARX_REVALIDATE_SECRET — shared secret with the storefront; leave unset for
# local dev.
