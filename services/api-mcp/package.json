{
  "name": "@sparx/api-mcp",
  "version": "0.0.0",
  "private": true,
  "description": "Sparx MCP server — exposes per-module tool registries (today: @sparx/crm's crmMcpTools) to Claude / ChatGPT / Copilot via Streamable HTTP. JWT-authenticated for now; API-key issuance lands when the dashboard's AI Integrations settings page does.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "start": "node --import tsx/esm src/index.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf .turbo dist *.tsbuildinfo"
  },
  "dependencies": {
    "@fastify/jwt": "^10.1.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@prisma/client": "^6.19.3",
    "@sparx/auth": "workspace:*",
    "@sparx/crm": "workspace:*",
    "@sparx/db": "workspace:*",
    "fastify": "^5.6.1",
    "fastify-plugin": "^5.0.1",
    "pino": "^9.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "dotenv": "^16.4.7",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
