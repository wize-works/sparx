{
  "name": "@sparx/api-rest",
  "version": "0.0.0",
  "private": true,
  "description": "Sparx public REST API — Fastify service hosting /v1/* endpoints. Authoritative for content, media, navigation, redirects, webhooks, and the headless surface consumed by storefronts, the dashboard, MCP, and external SDKs (docs/06-api-specification.md).",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "start": "node --import tsx/esm src/index.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf .turbo dist *.tsbuildinfo"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/jwt": "^9.0.4",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.6.0",
    "@google-cloud/pubsub": "^4.10.0",
    "@google-cloud/storage": "^7.16.0",
    "@prisma/client": "^6.19.3",
    "@sparx/auth": "workspace:*",
    "@sparx/cms-schemas": "workspace:*",
    "@sparx/crm": "workspace:*",
    "@sparx/crm-schemas": "workspace:*",
    "@sparx/db": "workspace:*",
    "fastify": "^5.6.1",
    "fastify-plugin": "^5.0.1",
    "mercurius": "^16.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "dotenv": "^16.4.7",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
