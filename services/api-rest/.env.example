# services/api-rest local dev defaults. Real values for sparx-prod come from
# the sparx-app-env ConfigMap + sparx-app-secrets Secret synced from
# Google Secret Manager (see k8s/apps/api-rest.example.yaml).

NODE_ENV=development
PORT=3100
LOG_LEVEL=debug

# Points at the same docker-compose Postgres the dashboard / @sparx/db use
# (packages/db/docker-compose.yml). RLS GUCs are set by withTenant() inside
# every tenant-scoped route handler.
DATABASE_URL="postgresql://sparx_app:devpassword@localhost:5544/sparx?schema=public"

# Shared with the dashboard. Must be >=32 chars; rotate by rolling both
# services together. Dev value is fine for local; prod reads it from the
# sparx-internal-jwt-secret entry in Google Secret Manager.
SPARX_INTERNAL_JWT_SECRET="dev-only-internal-jwt-secret-change-me-32chars"

# Pub/Sub: when GCP_PROJECT_ID is unset the publisher logs to stdout
# instead of calling Google Cloud (default for local dev).
# GCP_PROJECT_ID=
PUBSUB_TOPIC=sparx.events
