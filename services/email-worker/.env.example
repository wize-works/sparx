# services/email-worker local dev defaults. Real values for sparx-prod come
# from the sparx-app-env ConfigMap + sparx-app-secrets Secret synced from
# Google Secret Manager. Copy this file to `.env` to run locally.
#
# Pub/Sub-push consumer: nothing pushes to it in local dev, so it idles on its
# listen port. Provider selection (console in dev vs Mailgun in prod), default
# From address, and credentials are owned by @sparx/email, not this worker.

NODE_ENV=development
LOG_LEVEL=debug
# Distinct local port — workers default to 8080; cache-revalidation-worker
# owns 8080, so email-worker takes 8081 to avoid EADDRINUSE under `turbo dev`.
PORT=8081

# Same docker-compose Postgres the rest of the stack uses.
DATABASE_URL="postgresql://sparx_app:devpassword@localhost:5544/sparx?schema=public"
